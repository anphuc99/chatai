generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UsersMeta {
  userId       String    @id @map("user_id") // Firebase UID
  tutorialStep Int       @default(0) @map("tutorial_step")
  gems         Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  stories      Story[]
  sessions     Session[]
  shopTransactions ShopTransaction[]
  inventories      Inventory[]

  @@map("users_meta")
}

model ShopItem {
  id           String   @id
  name         String
  description  String   @db.Text
  priceGems    Int      @map("price_gems")
  category     String
  active       Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  transactions ShopTransaction[]
  inventories  Inventory[]

  @@index([category, active])
  @@map("shop_items")
}

model ShopTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  itemId    String   @map("item_id")
  pricePaid Int      @map("price_paid")
  source    String
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      UsersMeta @relation(fields: [userId], references: [userId], onDelete: Cascade)
  item      ShopItem  @relation(fields: [itemId], references: [id])

  @@index([userId, createdAt])
  @@map("shop_transactions")
}

model Inventory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  itemId     String   @map("item_id")
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now()) @map("acquired_at")

  user       UsersMeta @relation(fields: [userId], references: [userId], onDelete: Cascade)
  item       ShopItem  @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@map("inventory")
}

model Story {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  title           String
  initialSetting  String      @db.Text @map("initial_setting")
  currentProgress String      @db.Text @default("") @map("current_progress")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            UsersMeta   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  characters      Character[]
  sessions        Session[]

  @@index([userId])
  @@map("stories")
}

model Character {
  id           String    @id @default(uuid())
  storyId      String    @map("story_id")
  name         String
  age          Int?
  personality  String    @db.Text
  avatarUrl    String?   @map("avatar_url")
  voiceName    String    @map("voice_name")
  pitch        Float     @default(1.0)
  createdAt    DateTime  @default(now()) @map("created_at")

  story        Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([storyId])
  @@map("characters")
}

model Session {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  storyId   String    @map("story_id")
  status    String    @default("active")
  summary   String?   @db.Text
  startedAt BigInt    @map("started_at")
  endedAt   BigInt?   @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      UsersMeta @relation(fields: [userId], references: [userId], onDelete: Cascade)
  story     Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, storyId, status])
  @@index([storyId, status])
  @@index([userId, status, endedAt])
  @@map("sessions")
}

model Message {
  id            String     @id @default(uuid())
  sessionId     String     @map("session_id")
  characterId   String?    @map("character_id")
  role          String
  characterName String?    @map("character_name")
  text          String     @db.Text
  translation   String?    @db.Text
  emotion       String?
  intensity     String?
  words         Json?
  shopEvent     Json?      @map("shop_event")
  turnOrder     Int        @map("turn_order")
  timestamp     BigInt

  session       Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character     Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([sessionId, turnOrder])
  @@index([characterId])
  @@map("messages")
}
