rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chỉ User đã đăng nhập mới được đọc/ghi dữ liệu của chính họ
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Chỉ chủ sở hữu nhân vật mới được thao tác với nhân vật đó
    match /characters/{charId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
    }
  }
}
